{
	"name": "scweb",
	"version": "0.0.1",
	"private": true,
	"workspaces": [
		"api"
	],
	"scripts": {
		"dev": "vite dev --host",
		"dev:api": "npm run dev -w @scweb/api",
		"build": "vite build",
		"build:api": "npm run build -w @scweb/api",
		"check:api": "npm run check -w @scweb/api",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
		"test:integration": "playwright test",
		"test:e2e": "playwright test",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@iconify/svelte": "^4.2.0",
		"@lucide/svelte": "^0.506.0",
		"@playwright/test": "^1.51.1",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.20.2",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@types/eslint": "9.6.1",
		"@types/node": "^22.13.11",
		"@types/nprogress": "^0.2.3",
		"@types/uuid": "^10.0.0",
		"@typescript-eslint/eslint-plugin": "^8.27.0",
		"@typescript-eslint/parser": "^8.27.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"bits-ui": "^1.4.4",
		"eslint": "^9.23.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-svelte": "^3.3.3",
		"globals": "^17.7.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.3.3",
		"sharp": "^0.35.3",
		"svelte": "^5.25.2",
		"svelte-check": "^4.1.5",
		"tailwindcss": "^4.0.15",
		"tslib": "^2.8.1",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.63.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^6.2.2",
		"vitest": "^3.0.9"
	},
	"type": "module",
	"dependencies": {
		"@scweb/api": "workspace:*",
		"@sentry/sveltekit": "^10.64.0",
		"@supabase/ssr": "^0.6.1",
		"@supabase/supabase-js": "^2.49.1",
		"@tailwindcss/vite": "^4.0.15",
		"@types/three": "^0.174.0",
		"bad-words": "^4.0.0",
		"clsx": "^2.1.1",
		"hono": "^4.7.6",
		"razorpay": "^2.9.6",
		"snarkdown": "^2.0.0",
		"svelte-sonner": "^0.3.28",
		"tailwind-merge": "^2.2.0",
		"tailwind-variants": "^0.1.20",
		"three": "^0.174.0",
		"uuid": "^11.1.0"
	},
	"overrides": {
		"cookie": "^0.7.2"
	}
}
